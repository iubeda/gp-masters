{
  "name": "motogp-manager-backend",
  "version": "1.0.0",
  "description": "Backend API for GP Masters Manager MVP",
  "main": "server.js",
  "scripts": {
    "start": "npm run migrate:up && node server.js",
    "dev": "npm run migrate:up && nodemon server.js",
    "test": "vitest run --globals --no-file-parallelism",
    "test:watch": "vitest --globals --no-file-parallelism",
    "migrate": "node-pg-migrate",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.11.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}